# Anvil Configuration
#
# Copy this file to .env and fill in your values
# Or use --config flag to specify config file

# Provider settings
ANVIL_PROVIDER=mock
ANVIL_MODEL=mock-model

# OpenAI settings (if using openai_compatible provider)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic settings (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini settings (if using gemini provider)
# GEMINI_API_KEY=your-gemini-key

# Agent settings
ANVIL_MAX_STEPS=20
ANVIL_TIMEOUT_S=60
ANVIL_TEMPERATURE=0.2
ANVIL_HISTORY_WINDOW=3

# Memory settings
# ANVIL_MEMORY_DIR=.anvil/runs

# Skills to load (comma-separated)
# ANVIL_SKILLS=web_search,memory,files,commands

# Advanced settings
# ANVIL_PROVIDER_TIMEOUT_S=60
# ANVIL_MAX_RETRIES=2
# ANVIL_RETRY_BACKOFF_S=1.0
